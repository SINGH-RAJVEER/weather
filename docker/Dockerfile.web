# Development Dockerfile for Web frontend
FROM oven/bun:1.1.38-alpine

WORKDIR /app

# Copy root package files
COPY package.json bun.lockb* ./
COPY turbo.json biome.json ./

# Copy workspace packages (includes shared, types, config-typescript, database)
COPY packages ./packages

# Copy web app
COPY apps/web ./apps/web

# Native build deps for packages like better-sqlite3 (node-gyp)
RUN apk add --no-cache python3 make g++

# Install dependencies for the entire monorepo
RUN bun install

# Expose Vite dev server port
EXPOSE 5173

# Set working directory to web app
WORKDIR /app/apps/web

# Start development server with host flag to allow Docker network access
CMD ["bun", "run", "dev", "--host", "0.0.0.0"]
